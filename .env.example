# Copier ce fichier en .env et renseigner les valeurs réelles.
# Le fichier .env est exclu du dépôt git (voir .gitignore).

# Base de données MySQL
DB_URL=jdbc:mysql://localhost:3306/games?createDatabaseIfNotExist=true&serverTimezone=UTC
DB_USERNAME=your_mysql_user
DB_PASSWORD=your_mysql_password

# Authentification API (Basic Auth)
API_USERNAME=admin
API_PASSWORD=change_me_in_production
